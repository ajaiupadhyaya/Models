# API Keys (Optional - some features work without them)
# Get FRED API key: https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=

# Get Alpha Vantage API key: https://www.alphavantage.co/support/#api-key
ALPHA_VANTAGE_API_KEY=

# Get Polygon API key: https://polygon.io
POLYGON_API_KEY=

# Get IEX Cloud API key: https://iexcloud.io
IEX_API_KEY=

# Get Finnhub API key: https://finnhub.io
FINNHUB_API_KEY=

# Get NewsAPI key: https://newsapi.org
NEWSAPI_KEY=

# SEC EDGAR User-Agent (required by SEC)
SEC_USER_AGENT=financial-terminal/1.0 (contact: you@example.com)

# OpenAI API key (AI analysis)
OPENAI_API_KEY=

# Trading API Keys (Optional - for paper trading)
ALPACA_API_KEY=
ALPACA_API_SECRET=
ALPACA_BASE_URL=https://paper-api.alpaca.markets

# Configuration
ENABLE_PAPER_TRADING=false

# Runtime infrastructure (required for Docker/deploy)
DATABASE_URL=postgresql://trader:trading123@localhost:5432/trading_metrics
REDIS_URL=redis://localhost:6379/0
