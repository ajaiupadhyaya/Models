# ===================================================================
# Models — Terminal environment template
# Copy to `.env` and fill in. Anything left blank disables that feature
# (the app degrades gracefully — keyless providers still work).
# ===================================================================

# -------------------------------------------------------------------
# AUTH — required in any non-trivial deploy. Leaving AUTH_SECRET at
# the placeholder makes /api/auth/status report `configured: false`
# and the frontend skips the login screen.
# -------------------------------------------------------------------
TERMINAL_USER=demo
TERMINAL_PASSWORD=demo
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(48))"
AUTH_SECRET=change-me-in-production-use-long-random-string
AUTH_TOKEN_EXPIRE_MINUTES=60

# -------------------------------------------------------------------
# LOGGING / OBSERVABILITY
# -------------------------------------------------------------------
LOG_LEVEL=INFO
# Comma-separated list. Use "*" only for local dev. Production should list
# the exact frontend origin(s), e.g. https://models.vercel.app
CORS_ORIGINS=*

# -------------------------------------------------------------------
# DATA PROVIDERS — all optional. Keyless providers (yfinance, SEC EDGAR,
# CoinGecko) work without any key. Keyed providers gracefully no-op
# when their key is blank.
# -------------------------------------------------------------------
# Macro / fundamentals
FRED_API_KEY=
ALPHA_VANTAGE_API_KEY=
FMP_API_KEY=

# Market data (paid; free tiers available)
POLYGON_API_KEY=
IEX_API_KEY=
FINNHUB_API_KEY=

# News
NEWSAPI_KEY=

# SEC EDGAR User-Agent (required by SEC ToS — set to something identifiable)
SEC_USER_AGENT=models-terminal/1.0 (contact: you@example.com)

# AI analysis (OpenAI). Without this, AI endpoints return "unavailable".
OPENAI_API_KEY=

# -------------------------------------------------------------------
# PAPER TRADING (Alpaca) — optional
# -------------------------------------------------------------------
ENABLE_PAPER_TRADING=false
ALPACA_API_KEY=
ALPACA_API_SECRET=
ALPACA_API_BASE=https://paper-api.alpaca.markets

# -------------------------------------------------------------------
# INFRASTRUCTURE — optional. Without DATABASE_URL the DB-backed read
# helpers return empty/None and the rest of the app works on live data.
# For free hosting use Supabase or Neon (free Postgres). REDIS_URL is
# only needed if you re-enable the legacy Celery workers (v2).
# -------------------------------------------------------------------
DATABASE_URL=
REDIS_URL=

# -------------------------------------------------------------------
# SCHEDULER — runs daily/weekly/hourly data refresh in-process.
# Disable for stateless free-tier demos; enable for daily-driver use.
# -------------------------------------------------------------------
SCHEDULER_ENABLED=false

# -------------------------------------------------------------------
# FRONTEND BUILD-TIME — only needed for split-host deploys
# (e.g. frontend on Vercel, backend on Fly). Leave blank when serving
# the SPA from the same FastAPI process.
# -------------------------------------------------------------------
# VITE_API_ORIGIN=https://your-api.fly.dev
